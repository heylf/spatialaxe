/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/spatialxe Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Resource allocation aligned to AWS EC2 instance families:
      - CPU jobs:      r6id  (memory-optimized with NVMe SSD)
      - Segger GPU:    g6    (NVIDIA L4)
      - Cellpose GPU:  g6e   (NVIDIA L40S)
----------------------------------------------------------------------------------------
*/

process {

    cpus   = { 1    * (int)Math.pow(4, task.attempt - 1) }
    memory = { 6.GB * (int)Math.pow(4, task.attempt - 1) }
    time   = { 4.h  * (int)Math.pow(4, task.attempt - 1) }

    resourceLimits = [ cpus: 192, memory: 750.GB, time: 72.h ]

    errorStrategy = { task.exitStatus in ((130..145) + 104 + 2147483647) ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // =========================================================================
    // Standard nf-core CPU labels — target r6id instances
    // =========================================================================

    withLabel:process_single {
        // r6id.xlarge (4 vCPU, 32 GB)
        cpus   = { 1 }
        memory = { 6.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 4.h * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:process_low {
        // r6id.xlarge (4 vCPU, 32 GB)
        cpus   = { 2 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 12.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 4.h * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:process_medium {
        // r6id.2xlarge (8 vCPU, 64 GB)
        cpus   = { 6 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 56.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 8.h * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:process_high {
        // r6id.8xlarge (32 vCPU, 256 GB)
        cpus   = { 30 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 240.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 16.h * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:process_long {
        time = { 20.h * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:process_high_memory {
        memory = { 200.GB * (int)Math.pow(4, task.attempt - 1) }
    }

    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }

    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    // =========================================================================
    // GPU labels
    // =========================================================================

    // Multi-GPU processes (SEGGER train/predict)
    // g6.12xlarge (48 vCPU, 192 GB, 4x NVIDIA L4)
    withLabel:process_gpu {
        ext.use_gpu = { params.use_gpu }
        accelerator = { params.use_gpu ? 1 : null }
        containerOptions = { "--shm-size ${task.memory.toGiga().intValue()}g" }
    }

    // Single-GPU processes (Cellpose, StarDist)
    // g6e.8xlarge (32 vCPU, 256 GB, 1x NVIDIA L40S) — request 1 GPU
    // Full Xenium OME-TIFFs need ~192 GB for cellpose inference
    withLabel:gpu_single {
        ext.use_gpu = { params.use_gpu }
        accelerator = { params.use_gpu ? 1 : null }
        cpus   = { 12 }
        memory = { 192.GB * (int)Math.pow(2, task.attempt - 1) }
        time   = { 32.h * task.attempt }
    }

    // =========================================================================
    // Infrastructure-specific overrides (withName)
    // These tune for specific AWS instance types beyond what labels provide.
    // =========================================================================

    // MultiQC: r6id.4xlarge (16 vCPU, 128 GB)
    withName:".*MULTIQC.*" {
        cpus   = { 14 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 120.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 8.h * (int)Math.pow(4, task.attempt - 1) }
    }

    // XeniumRanger: must use local scratch on Fusion CEs
    // Without scratch=true, Fusion fails to collect large output bundles (exit=0 failures)
    withName:".*XENIUMRANGER.*" {
        scratch = true
    }

    // SEGGER_TRAIN: multi-GPU distributed training
    // g6.12xlarge (48 vCPU, 192 GB, 4x L4) — request full instance
    // accelerator scales with retries: 4 → 8 GPUs, capped at params.devices
    withName:".*SEGGER_TRAIN" {
        accelerator = { params.use_gpu ? Math.min((int) Math.pow(2, task.attempt + 1), params.devices as int) : null }
        cpus   = { 46 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 180.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 48.h * (int)Math.pow(4, task.attempt - 1) }
    }

    // SEGGER_PREDICT: multi-GPU inference
    // g6.16xlarge (64 vCPU, 256 GB) — needs 200+ GB for large samples
    withName:".*SEGGER_PREDICT" {
        accelerator = { params.use_gpu ? (params.devices as int) : null }
        cpus   = { 56 * (int)Math.pow(4, task.attempt - 1) }
        memory = { 224.GB * (int)Math.pow(4, task.attempt - 1) }
        time   = { 16.h * (int)Math.pow(4, task.attempt - 1) }
    }
}
